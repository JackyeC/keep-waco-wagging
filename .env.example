# Supabase (dedicated Keep Waco Wagging project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend) for lead notifications + Daily Sniff review alerts
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@keepwacowagging.com
LEAD_NOTIFICATION_EMAIL=info@platinumscoops.com
LEAD_NOTIFICATION_BCC=jackyeclayton@gmail.com

# Amazon affiliate tag for the Shop page
AMAZON_ASSOCIATES_TAG=

# Public site URL (used to build absolute admin links in notification emails)
NEXT_PUBLIC_SITE_URL=https://keepwacowagging.com

# --- KWW Daily Sniff (draft-first local content desk) ---
# Shared secret required to call the /api/cron/daily-sniff-* routes.
DAILY_SNIFF_CRON_SECRET=
# OpenAI key used to score items and draft briefs.
OPENAI_API_KEY=
# Optional override for the model used when drafting briefs.
DAILY_SNIFF_MODEL=gpt-4o-mini
# Where the "new drafts ready" review email is sent (defaults to LEAD_NOTIFICATION_EMAIL).
DAILY_SNIFF_NOTIFICATION_EMAIL=
# Temporary token gating the private /admin/daily-sniff queue until real auth is added.
DAILY_SNIFF_ADMIN_TOKEN=
